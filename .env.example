# Global IP mode for targets without per-target ip_mode.
# Allowed values: ipv4, ipv6
IP_MODE=ipv4

# Update interval in seconds for `cloudflare-ddns run`
# and for systemd service daemon mode.
UPDATE_INTERVAL=120

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# JSON array with Cloudflare targets.
# Each target supports:
# - name       (required)
# - type       (required): A or AAAA
# - token      (required)
# - zone_id    (optional if zone_name exists)
# - zone_name  (optional if zone_id exists)
# - proxied    (optional): true / false
# - ip_mode    (optional): ipv4 / ipv6
CF_TARGETS_JSON=[
  {
    "name": "example.com",
    "type": "A",
    "zone_name": "example.com",
    "token": "your_cloudflare_api_token_here",
    "proxied": false
  },
  {
    "name": "ipv6.example.com",
    "type": "AAAA",
    "zone_name": "example.com",
    "token": "your_second_cloudflare_api_token_here",
    "proxied": false,
    "ip_mode": "ipv6"
  }
]
