# Global IP mode for targets without per-target ip_mode.
# Allowed values: ipv4, ipv6
IP_MODE=ipv4

# Update interval in seconds for `cloudflare-ddns run`
UPDATE_INTERVAL=120

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Recommended way: put targets into a separate JSON file.
CF_TARGETS_FILE=/opt/cloudflare-ddns/targets.json

# Optional alternative: one-line JSON in .env instead of CF_TARGETS_FILE
# CF_TARGETS_JSON=[{"name":"example.com","type":"A","zone_name":"example.com","token":"your_cloudflare_api_token_here","proxied":false}]
